# Supabase connection (required, bundled into client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Trip authentication code (required, server-only)
# This is the password users enter to access the trip. Never expose in client code.
TRIP_CODE=change-me
